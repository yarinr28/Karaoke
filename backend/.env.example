PORT=8000
# Absolute path to the shared songs directory
SONGS_DIR=../songs
# MongoDB connection
MONGO_URL=mongodb://localhost:27017
MONGO_DB=karaoke
# Musixmatch API key (https://developer.musixmatch.com/)
MUSIXMATCH_API_KEY=
# Whisper model: tiny / base / small / medium / large-v2 / large-v3
# large-v3 is strongly recommended for forced alignment accuracy
WHISPER_MODEL=large-v3
# Device: cuda or cpu
WHISPER_DEVICE=cpu
# Compute type for faster-whisper: float16 (GPU) / int8 (CPU)
WHISPER_COMPUTE=int8
