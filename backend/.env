PORT=8000
SONGS_DIR=../songs

# MongoDB
MONGO_URL=mongodb://localhost:27017
MONGO_DB=karaoke

# Musixmatch API key (optional — https://developer.musixmatch.com/)
MUSIXMATCH_API_KEY=

# Whisper model — large-v3 is best quality, requires ~3 GB VRAM
WHISPER_MODEL=large-v3
# GPU: set to cuda for RTX 3060 Ti (8 GB VRAM → fits large-v3 in float16)
WHISPER_DEVICE=cuda
WHISPER_COMPUTE=float16
